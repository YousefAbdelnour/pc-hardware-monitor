{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PC Hardware Monitor",
  "version": "0.1.0",
  "identifier": "com.youssef.pchardwaremonitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -- --host",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "pc-hardware-monitor-main",
        "title": "PC Hardware Monitor",
        "width": 1400,
        "height": 900,
        "dataDirectory": "webview",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/pc-monitor-backend"
    ],
    "resources": [
      "resources/**/*"
    ]
  }
}
